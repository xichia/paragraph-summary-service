# Safe local defaults. These let the API, cache, artifact writer, and tests run offline.
LLM_PROVIDER=mock
ALLOW_EXTERNAL_PROVIDER_CALLS=false
SUMMARY_DB_PATH=.local/paragraph_summary.sqlite
SUMMARY_ARTIFACT_DIR=output/paragraph_summaries
MAX_RECORDS_PER_REQUEST=1000
MAX_RECORD_CHARS=20000
MAX_TOTAL_CHARS=5000000
MAX_UPLOAD_BYTES=5000000
TOKEN_CHARS_PER_TOKEN=4

# Primary real-provider path: Gemini-backed one-sentence paragraph summaries.
# Enable only with an authorised key/project and provider limits that match your account/project.
# LLM_PROVIDER=gemini
# ALLOW_EXTERNAL_PROVIDER_CALLS=true
# GEMINI_API_KEY=your_authorised_key_here
# GEMINI_MODEL=gemini-2.5-flash-lite
# GEMINI_INPUT_TPM_LIMIT=250000
# GEMINI_SAFE_INPUT_TOKEN_TARGET=225000
# GEMINI_REQUESTS_PER_MINUTE=1
# GEMINI_TIMEOUT_SECONDS=90
